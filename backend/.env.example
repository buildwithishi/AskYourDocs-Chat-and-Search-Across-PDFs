# App
ENVIRONMENT=development
SECRET_KEY=change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database (Neon — must use the asyncpg driver scheme)
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname?ssl=require

# CORS
FRONTEND_ORIGINS=http://localhost:5173,https://askyourdocs.vercel.app

# Redis (caching now, background job queue later)
REDIS_URL=redis://localhost:6379/0

# File storage (local now, Cloudflare R2 in production — selected via STORAGE_BACKEND)
STORAGE_BACKEND=local
UPLOAD_DIR=/data/uploads
MAX_UPLOAD_MB=25
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# Vector store (ChromaDB now, behind a swappable interface)
CHROMA_PERSIST_DIR=/data/chroma
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Retrieval / RAG
RETRIEVAL_TOP_K=5
RETRIEVAL_SIMILARITY_THRESHOLD=0.0
CONVERSATION_HISTORY_LENGTH=10

# LLM provider (selected via LLM_PROVIDER: ollama | openai | groq | openrouter; behind a swappable interface)
LLM_PROVIDER=ollama
LLM_TIMEOUT_SECONDS=60
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# Logging
LOG_LEVEL=INFO
